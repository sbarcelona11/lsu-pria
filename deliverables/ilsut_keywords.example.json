{
  "hola": {
    "include": ["hola", "buenas", "buen dia", "buenos dias", "buenas tardes", "buenas noches"],
    "phrases": ["hola a todos", "hola a todas", "muy buenas", "buen dia para todos"],
    "exclude": ["holanda"]
  },
  "gracias": {
    "include": ["gracias", "agradezco", "agradecemos", "agradecido", "agradecida"],
    "phrases": ["muchas gracias", "te agradezco", "les agradecemos", "muy agradecido", "muy agradecida"],
    "fuzzy": [{"text": "grasias", "score_cutoff": 90}],
    "fuzzy_phrases": [{"text": "muchas grasias", "score_cutoff": 88}],
    "exclude": ["gracia"],
    "phrase_exclude": ["gracias a dios", "gracias al apoyo"]
  },
  "ayuda": {
    "include": ["ayuda", "auxilio", "socorro", "apoyo", "colaboracion"],
    "phrases": ["necesito ayuda", "pedir ayuda", "pedimos ayuda", "solicitar ayuda", "brindar apoyo"],
    "phrase_exclude": ["ayuda memoria", "ayuda economica"]
  },
  "si": {
    "include": ["si"],
    "regex": ["\\bs[ií]\\b"],
    "phrases": ["si claro", "si por supuesto", "si se puede", "asi es"],
    "phrase_exclude": ["si bien", "si no", "como si"]
  },
  "no": {
    "include": ["no"],
    "regex": ["\\bno\\b"],
    "phrases": ["no se", "no puedo", "no quiero", "no hay", "para nada"],
    "phrase_exclude": ["no obstante", "no solo", "no solamente"]
  },
  "por_favor": {
    "include": ["por favor", "porfa"],
    "phrases": ["te pido por favor", "por favor ayudame", "por favor ayudenme"]
  },
  "buenos_dias": {
    "include": ["buenos dias", "buen dia"],
    "phrases": ["muy buenos dias", "buen dia para todos"],
    "exclude": ["dias"]
  },
  "permiso": {
    "include": ["permiso", "disculpe", "disculpa"],
    "phrases": ["con permiso", "me permite", "permiso por favor"]
  }
}
